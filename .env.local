# Local development — used when running `npm run dev` directly (without Docker)
# Copy this file to .env and fill in values if running outside Docker

DATABASE_URL=postgresql://egs:egspassword@localhost:5432/egs_trip_tracker
NODE_ENV=development
PORT=5000

# Required for AI trip report extraction (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
